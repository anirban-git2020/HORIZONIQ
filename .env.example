# HorizonIQ pipeline tokens (free — one-time setup)
# Copy to .env.local and fill in values. Never commit real tokens.

# GitHub: read-only Personal Access Token (5,000 req/hr)
# https://github.com/settings/tokens — scope: public_repo (read)
GITHUB_TOKEN=

# Product Hunt: free developer token (non-commercial OK for MVP)
# https://api.producthunt.com/v2/oauth/applications
PRODUCT_HUNT_TOKEN=

# Optional for GitHub Actions only (repo secret PIPELINE_GITHUB_TOKEN).
# Local dev uses GITHUB_TOKEN above. CI falls back to github.token if unset.
# PIPELINE_GITHUB_TOKEN=

# Analytics (optional). When NEXT_PUBLIC_POSTHOG_KEY is set, events are sent to
# PostHog in addition to the local buffer. Leave blank to keep analytics
# local-only (inspect via getAnalyticsLog() in the browser console).
# Project API key + host from https://posthog.com (free tier).
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
