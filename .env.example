# HorizonIQ environment variables (example)
# Copy to .env.local for local development.

# --- Analytics (Sprint 4A) ---

# Microsoft Clarity — production only, lazy-loaded
# NEXT_PUBLIC_CLARITY_PROJECT_ID=

# Optional PostHog product analytics
# NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Vercel Analytics + Speed Insights require no env vars when deployed on Vercel.
# Enable Web Analytics in the Vercel project dashboard.

# Canonical site URL for SEO metadata, sitemap, and Open Graph
# NEXT_PUBLIC_SITE_URL=https://horizoniq-beta.vercel.app

# --- Data pipeline (CI / local ingest) ---

# GITHUB_TOKEN=
# PRODUCT_HUNT_TOKEN=
