# Normalize line endings: store text as LF in the repo, so Windows CRLF
# working copies no longer show hundreds of phantom "changes".
* text=auto

# Explicitly treat common binary assets as binary (never normalize).
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.webp binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.otf   binary
*.pdf  binary
